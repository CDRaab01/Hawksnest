<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Push: POST_NOTIFICATIONS (runtime, Android 13+); the ntfy listener runs as a
         specialUse foreground service and restarts after a reboot. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Offer to exempt the push listener from battery optimization (One UI dozes long-idle
         foreground services); requested only from Settings when the user enables push. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Two-way audio ("talk"): captures the mic to stream to the camera back-channel. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Package visibility (Android 11+): the Settings → Tailscale panel checks whether the official
         Tailscale app is installed (to "Open" it vs. send the user to install it). -->
    <queries>
        <package android:name="com.tailscale.ipn" />
    </queries>

    <application
        android:name=".HawksnestApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Hawksnest">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Hawksnest">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Holds the streaming connection to self-hosted ntfy so doorbell/alarm
             pushes arrive with the app closed. specialUse = "connection to a
             self-hosted server" (the honest type; app is sideloaded, not on Play). -->
        <service
            android:name=".push.NtfyPushService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps a connection to the household's self-hosted ntfy server for doorbell and alarm push notifications." />
        </service>

        <!-- ── Home-screen widgets ────────────────────────────────────────────────────────────
             Three providers rather than one, so the launcher's picker lists them by name and each
             gets its own size and preview. They share one configuration activity, which works out
             which widget it is configuring from the provider that launched it. The widgets talk to
             Home Assistant over REST (widget/data/WidgetHaClient) — see ARCHITECTURE.md. -->
        <receiver
            android:name=".widget.LightWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_light_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/light_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.LockWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_lock_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/lock_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.AlarmWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_alarm_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/alarm_widget_info" />
        </receiver>

        <!-- Launched by the system when a widget is dropped on the home screen. Exported because
             the launcher starts it; it takes no input beyond the widget id the system supplies. -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.Hawksnest">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Restart the listener after a reboot (only if push is enabled). -->
        <receiver
            android:name=".push.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
