<?xml version="1.0" encoding="utf-8"?>
<!--
  PULSE tokens for the widget layer's shape drawables — the LIGHT theme; `values-night/` holds the
  dark counterparts and is the one that matters most (these widgets are dark-first).

  Why hex lives here at all: Glance styles text and flat fills from Kotlin `ColorProvider`s built
  off `ui/theme/Color.kt`, but a gradient or a rim stroke has to come from an XML `<shape>`, and a
  drawable can only reference `@color`. So this file is the drawable-side mirror of Color.kt —
  every value below names the constant it came from, and the two must be edited together.

  Light values use the `*Deep` channel variants, exactly as `lightPulseColors()` does: the raw
  channel seeds are tuned for dark surfaces and fail contrast on white.
-->
<resources>
    <!-- Panel: lightPulseColors() panel → panelHigh. -->
    <color name="widget_panel_top">#FFFFFFFF</color>
    <color name="widget_panel_bottom">#FFF1F3F6</color>
    <!-- lightPulseColors().hairline -->
    <color name="widget_hairline">#1A000000</color>
    <!-- Button face: lightPulseColors().panelHigh -->
    <color name="widget_button_face">#FFF1F3F6</color>

    <!-- Rims: the channel base at 45%, Remnant's lit-edge treatment scaled down for a widget. -->
    <color name="widget_rim_effort">#732A5BFF</color>     <!-- PulseBlueDeep -->
    <color name="widget_rim_streak">#73C2410C</color>     <!-- PulseOrangeDeep -->
    <color name="widget_rim_recovery">#73047857</color>   <!-- PulseGreenDeep -->

    <!-- Soft channel washes at 12%: the header chip's fill, and the tinted resting button (a
         control that is live but not engaged — the lock's next action). Same Deep seeds as above. -->
    <color name="widget_soft_effort">#1F2A5BFF</color>    <!-- PulseBlueDeep -->
    <color name="widget_soft_streak">#1FC2410C</color>    <!-- PulseOrangeDeep -->
    <color name="widget_soft_recovery">#1F047857</color>  <!-- PulseGreenDeep -->

    <!-- energyGradient (light): the celebration/streak voice — a lit lamp, a cautionary confirm. -->
    <color name="widget_energy_start">#FFFF6B35</color>
    <color name="widget_energy_end">#FFF5A623</color>
    <!-- heroGradient (light): PulseBlueDeep → PulseIndigoDeep. An armed panel. -->
    <color name="widget_hero_start">#FF2A5BFF</color>
    <color name="widget_hero_end">#FF5B2BE0</color>
    <!-- Recovery: PulseGreenDeep → PulseGreenDeeper. Secure, settled. -->
    <color name="widget_recovery_start">#FF047857</color>
    <color name="widget_recovery_end">#FF064E3B</color>
</resources>
