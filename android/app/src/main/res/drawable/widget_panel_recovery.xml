<?xml version="1.0" encoding="utf-8"?>
<!-- Widget panel with a recovery-lit rim. See widget_panel.xml for the recipe. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/widget_panel_top"
        android:endColor="@color/widget_panel_bottom"
        android:type="linear" />
    <corners android:radius="20dp" />
    <stroke android:width="1dp" android:color="@color/widget_rim_recovery" />
</shape>
