<?xml version="1.0" encoding="utf-8"?>
<!-- The header's glyph chip when no channel is speaking: the raised panel tone held by a
     hairline, so an unknown or resting state stays quiet. The widget_chip_<channel> siblings
     swap the fill for a soft channel wash. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/widget_button_face" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="@color/widget_hairline" />
</shape>
