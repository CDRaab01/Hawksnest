<?xml version="1.0" encoding="utf-8"?>
<!-- A resting control: the raised panel tone, held by a hairline, under a press ripple — the one
     animation RemoteViews grants a widget, and what keeps a tap from feeling dead. The filled
     variants (widget_button_energy / _hero / _recovery) carry a PULSE gradient instead; the soft
     variants a channel wash. The shape's alpha masks the ripple, so it stays inside the corners. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/widget_ripple">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_button_face" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/widget_hairline" />
        </shape>
    </item>
</ripple>
