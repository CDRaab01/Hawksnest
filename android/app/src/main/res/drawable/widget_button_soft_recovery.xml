<?xml version="1.0" encoding="utf-8"?>
<!-- A live-but-resting control wearing a soft recovery wash — the lock's "Lock" at rest.
     See widget_button_soft_streak.xml. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/widget_rim_recovery">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_soft_recovery" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/widget_rim_recovery" />
        </shape>
    </item>
</ripple>
