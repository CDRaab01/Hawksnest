<?xml version="1.0" encoding="utf-8"?>
<!--
  The widget's surface, in PULSE's instrument-panel language: a panel lit from above (panelHigh
  falling to ink), held by a 1dp hairline rather than a shadow. Pulse's own rule — "depth comes
  from hairline strokes and tone, not big radii or shadows" — and the reason a flat grey slab
  looked cheap on the wallpaper.

  The `widget_panel_<channel>.xml` siblings are this exact shape with the hairline swapped for a
  channel-lit rim, which is how a widget shows state at its edge: green when the door is locked,
  orange when it jammed, blue when the alarm is armed.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="@color/widget_panel_top"
        android:endColor="@color/widget_panel_bottom"
        android:type="linear" />
    <corners android:radius="20dp" />
    <stroke android:width="1dp" android:color="@color/widget_hairline" />
</shape>
