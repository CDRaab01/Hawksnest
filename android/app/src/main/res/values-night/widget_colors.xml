<?xml version="1.0" encoding="utf-8"?>
<!--
  PULSE tokens for the widget layer's shape drawables — the DARK theme. See `values/widget_colors.xml`
  for why these live in XML rather than only in `ui/theme/Color.kt`.

  The panel runs PulsePanelHigh → PulseInk top to bottom, so a widget reads as lit from above the
  way the in-app panels do, rather than as a flat grey slab on the wallpaper.
-->
<resources>
    <!-- Panel: PulsePanelHigh → PulseInk. -->
    <color name="widget_panel_top">#FF1A1E25</color>
    <color name="widget_panel_bottom">#FF0B0D10</color>
    <!-- darkPulseColors().hairline -->
    <color name="widget_hairline">#14FFFFFF</color>
    <!-- Button face: PulsePanelHigh -->
    <color name="widget_button_face">#FF1A1E25</color>

    <!-- Rims: the channel base at 45%. Remnant lights its surfaces at the edge rather than
         shadowing them — a locked door glows green at the rim, a jam glows orange. -->
    <color name="widget_rim_effort">#734D7CFF</color>     <!-- PulseBlue -->
    <color name="widget_rim_streak">#73FF8A5C</color>     <!-- PulseOrange -->
    <color name="widget_rim_recovery">#7334D399</color>   <!-- PulseGreen -->

    <!-- energyGradient (dark): PulseOrange → PulseAmber. -->
    <color name="widget_energy_start">#FFFF8A5C</color>
    <color name="widget_energy_end">#FFF5A623</color>
    <!-- heroGradient (dark): PulseBlueDeep → PulseIndigo. -->
    <color name="widget_hero_start">#FF2A5BFF</color>
    <color name="widget_hero_end">#FF7A45F0</color>
    <!-- Recovery: PulseGreen → PulseGreenDeep. -->
    <color name="widget_recovery_start">#FF34D399</color>
    <color name="widget_recovery_end">#FF047857</color>
</resources>
