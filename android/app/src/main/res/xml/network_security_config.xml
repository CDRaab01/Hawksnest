<?xml version="1.0" encoding="utf-8"?>
<!--
  RELEASE posture: cleartext HTTP is DISALLOWED. Hawksnest reaches Home Assistant only over HTTPS —
  the k3s nginx proxy is fronted by Tailscale Serve (TLS at https://<host>.ts.net:8443, a real
  Let's Encrypt cert, tailnet-only). Point Settings at that HTTPS URL.

  This replaces the earlier deliberate cleartext=true (which existed because the HA host could be a
  bare 100.x Tailscale IP that a scoped <domain-config> can't match) — now that TLS fronts the
  proxy, cleartext is off entirely. Reverting to a plain-HTTP host would mean re-opening cleartext
  here and losing the security win.

  Debug builds add a narrow cleartext exception for the instrumented mock-HA at 10.0.2.2 — see
  src/debug/res/xml/network_security_config.xml. That override never ships in a release APK.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
