<?xml version="1.0" encoding="utf-8"?>
<!-- See light_widget_info.xml for the sizing and refresh reasoning; the lock widget is the same
     shape with one full-width action button. Squeezed to its compact tier it drops the device
     name from the header but never the state or the time it was read. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:targetCellWidth="3"
    android:targetCellHeight="2"
    android:minResizeWidth="110dp"
    android:minResizeHeight="40dp"
    android:resizeMode="horizontal|vertical"
    android:updatePeriodMillis="1800000"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:previewImage="@drawable/ic_widget_lock"
    android:description="@string/widget_lock_description"
    android:configure="com.hawksnest.widget.WidgetConfigActivity"
    android:widgetCategory="home_screen" />
